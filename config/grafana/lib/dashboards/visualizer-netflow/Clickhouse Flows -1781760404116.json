          "formattedQuery": "/* grafana dashboard='Clickhouse Flows ', user=admin */\nSELECT\n    time_received_ns AS \"Timestamp\",\n    \n    IPv4NumToString(reinterpretAsUInt32(substring(src_addr, 1, 4))) AS \"Source IP\",\n    src_port AS \"Src Port\",\n    \n    IPv4NumToString(reinterpretAsUInt32(substring(dst_addr, 1, 4))) AS \"Dest IP\",\n    dst_port AS \"Dst Port\",\n    dictGetString('dictionaries.protocols', 'name', toUInt8(proto)) AS \"Proto\",\n    bytes AS \"Bytes\",\n    packets AS \"Packets\"\nFROM default.flows_raw\nWHERE time_received_ns >= toDateTime64(1781549387, 9)\n  AND time_received_ns <= toDateTime64(1781570987, 9)\n  AND ('$Source_ASN' = 'All' OR '$Source_ASN' = '*' OR src_as = toUInt32OrZero('$Source_ASN'))\n  AND ('$dst_as' = 'All' OR '$dst_as' = '*' OR dst_as = toUInt32OrZero('$dst_as'))\nORDER BY time_received_ns DESC\nLIMIT 100",
          "interval": "",
          "intervalFactor": 1,
          "nullifySparse": false,
          "query": "SELECT\n    time_received_ns AS \"Timestamp\",\n    -- Slice the first 4 bytes and interpret them as an IPv4 integer\n    IPv4NumToString(reinterpretAsUInt32(substring(src_addr, 1, 4))) AS \"Source IP\",\n    src_port AS \"Src Port\",\n    -- Slice the first 4 bytes and interpret them as an IPv4 integer\n    IPv4NumToString(reinterpretAsUInt32(substring(dst_addr, 1, 4))) AS \"Dest IP\",\n    dst_port AS \"Dst Port\",\n    dictGetString('dictionaries.protocols', 'name', toUInt8(proto)) AS \"Proto\",\n    bytes AS \"Bytes\",\n    packets AS \"Packets\"\nFROM default.flows_raw\nWHERE time_received_ns >= toDateTime64($from, 9)\n  AND time_received_ns <= toDateTime64($to, 9)\n  AND ('$Source_ASN' = 'All' OR '$Source_ASN' = '*' OR src_as = toUInt32OrZero('$Source_ASN'))\n  AND ('$dst_as' = 'All' OR '$dst_as' = '*' OR dst_as = toUInt32OrZero('$dst_as'))\nORDER BY time_received_ns DESC\nLIMIT 100",
