          "formattedQuery": "/* grafana dashboard='Clickhouse Flows ', user=admin */\nSELECT\n    IPv4NumToString(reinterpretAsUInt32(substring(reverse(src_addr),13,4))) AS src_addr,\n    IPv4NumToString(reinterpretAsUInt32(substring(reverse(dst_addr),13,4))) AS dst_addr,\n    src_port,\n    dst_port,\n    dictGetOrDefault('dictionaries.protocols', 'name',\n      toUInt64(proto), toString(proto)) AS proto,\n    sum(bytes * sampling_rate) AS bytes,\n    sum(packets) AS packets,\n    count() AS flow_count\nFROM default.flows_raw\nWHERE date >= toDate(1781544568) AND date <= toDate(1781566168) AND time_flow_start_ns >= 1781544568 AND time_flow_start_ns <= 1781566168\nGROUP BY src_addr, dst_addr, src_port, dst_port, proto\nORDER BY bytes DESC\nLIMIT 20",
