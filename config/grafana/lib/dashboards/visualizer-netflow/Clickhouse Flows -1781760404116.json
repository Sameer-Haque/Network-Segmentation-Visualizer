          "formattedQuery": "/* grafana dashboard='Clickhouse Flows ', user=admin */\nSELECT\n    toStartOfFiveMinute(time_received_ns) AS t,\n    multiIf(etype=2048,'IPv4',\n            etype=34525,'IPv6',\n            etype=2054,'ARP',\n            concat('0x',hex(etype))) AS etype,\n    sum(bytes * sampling_rate) AS bytes\nFROM default.flows_raw\nWHERE date >= toDate(1781408172) AND date <= toDate(1781429772) AND time_received_ns >= toDateTime64(1781408172,3) AND time_received_ns <= toDateTime64(1781429772,3)\nGROUP BY t, etype\nORDER BY t ASC",
