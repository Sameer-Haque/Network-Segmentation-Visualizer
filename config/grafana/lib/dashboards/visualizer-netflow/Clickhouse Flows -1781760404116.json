          "nullifySparse": false,
          "query": "SELECT\n    toStartOfFiveMinute(time_received_ns) AS t,\n    multiIf(etype=2048,'IPv4',\n            etype=34525,'IPv6',\n            etype=2054,'ARP',\n            concat('0x',hex(etype))) AS etype,\n    sum(bytes * sampling_rate) AS bytes\nFROM $table\nWHERE $timeFilter\nGROUP BY t, etype\nORDER BY t ASC",
          "refId": "A",
          "round": "0s",
          "skip_comments": true,
