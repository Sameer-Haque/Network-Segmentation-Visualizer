            "alias": "Total used",
            "binary": {
              "left": {
                "matcher": {
                  "id": "byName",
                  "options": "Value #A"
                }
              },
              "operator": "/",
              "right": {
                "matcher": {
                  "id": "byName",
                  "options": "Total Memory"
                }
              }
            },
            "mode": "binary",
            "reduce": {
              "reducer": "sum"
            },
            "replaceFields": true
